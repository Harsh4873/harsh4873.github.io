# Firebase Admin SDK credentials for local backend scripts.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_CLIENT_ID=

# Local HTTP backend port used by pickgrader_server.py.
PORT=8765

# Hosted/backend auth controls.
PICKLEDGER_REQUIRE_AUTH=true
PICKLEDGER_ADMIN_EMAILS=hdav4873@gmail.com

# Optional frontend build-time backend URL for GitHub Pages.
VITE_PICKLEDGER_BACKEND_URL=
