rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwnUserDoc(userId) {
      return request.auth != null && (
        request.auth.uid == userId ||
        (request.auth.token.email != null && request.auth.token.email == userId)
      );
    }

    function isPickLedgerAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email == "hdav4873@gmail.com";
    }

    // Admin picks cache - readable by any signed-in user, writable only by Admin SDK.
    match /admin_picks/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Legacy latest-picks cache used by the GitHub Pages model-results banner.
    match /picks/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Shared model performance rankings. Everyone can read the global model
    // leaderboard; only the admin account can publish the canonical ledger.
    match /rankings/{docId} {
      allow read: if request.auth != null;
      allow write: if isPickLedgerAdmin();
    }

    // Per-user data - each user can only read and write their own document.
    match /users/{userId} {
      allow read, write: if isOwnUserDoc(userId);
    }

    // Legacy per-user subcollections retained for backward compatibility.
    match /users/{userId}/{document=**} {
      allow read, write: if isOwnUserDoc(userId);
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
